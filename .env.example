# ============================================================
# Job Search Automation — Example Environment Variables
# Copy this to .env and fill in your values.
# ============================================================

# --- Notion (required for Notion output) ---
NOTION_API_TOKEN=ntn_your_integration_token_here
# Filled in automatically after running setup_notion.py:
NOTION_P1_DB_ID=your_p1_database_id
NOTION_P0_DB_ID=your_p0_database_id

# --- Gemini AI (free tier scoring — 1M tokens/day, 15 RPM) ---
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Google Doc (your base resume, "Anyone with link" view access) ---
RESUME_GDOC_ID=your_google_doc_id_here

# --- Google Service Account (enables GDoc creation + GSheets write) ---
# Optional — without this, tailored resumes are saved locally as Markdown
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
# Filled in after running: python -c "from integrations.google_sheets import create_spreadsheet; ..."
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# --- Apify (LinkedIn + Indeed scraping, free tier available) ---
# Get a key at https://apify.com — without it those two scouts are skipped
APIFY_API_KEY=your_apify_api_key_here

# --- Scheduling ---
JOB_SCAN_TIME=09:00   # 24h local time; scheduler.py runs daily at this time

# --- Legacy n8n settings ---
ANTHROPIC_API_KEY=
GMAIL_EMAIL=your@email.com
GMAIL_APP_PASSWORD=
N8N_HOST=localhost
N8N_PORT=5678
