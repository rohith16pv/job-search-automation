# Job Search Automation Settings
PROJECT_NAME=Job Search Automation
APP_ENV=development

# Email Configuration
GMAIL_EMAIL=pv.rohith96@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Google Docs Configuration
GOOGLE_DOCS_FOLDER_ID=your-google-drive-folder-id-here
GOOGLE_SHEETS_CREDENTIALS_PATH=/path/to/service-account-key.json

# n8n Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_BASE_URL=http://localhost:5678

# Optional: LinkedIn Scraping (Apify)
APIFY_API_KEY=your_apify_api_key_here

# Optional: Alternative Email Service
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Optional: Headless Browser (for Playwright)
PLAYWRIGHT_HEADLESS=true

# Automation Settings
JOB_SCAN_SCHEDULE=0 9 * * 3    # Wednesday 9am
DIGEST_SCHEDULE=0 9 * * 5      # Friday 9am
MAX_EMAILS_PER_DAY=5
MAX_EMAILS_PER_COMPANY_PER_WEEK=3

# Filtering
TARGET_ROLES=Senior PM,Staff PM,Product Manager
TARGET_LOCATIONS=San Francisco,Remote,Bay Area
MIN_RELEVANCE_SCORE=3.5

# Logging
LOG_LEVEL=info
LOG_FILE=logs/job-search-automation.log
